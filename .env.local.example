# Copy to .env.local — never commit real secrets

# Monday.com CRM (server-side only)
MONDAY_API_KEY="your-monday-api-token"
MONDAY_BOARD_ID="18393484200"

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# PostgreSQL
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Optional Monday column overrides
# MONDAY_COLUMN_EMAIL=
# MONDAY_COLUMN_PHONE=
# MONDAY_COLUMN_COMPANY_NAME=
# MONDAY_COLUMN_VALUATION_MIDPOINT=
# MONDAY_COLUMN_SECTOR=
# MONDAY_COLUMN_FILES=files
