{
  "name": "valubot",
  "version": "1.0.0",
  "private": true,
  "description": "Equify by SBC valuation platform gateway",
  "scripts": {
    "dev": "next dev",
    "build": "tsc -p tsconfig.json --noEmit && next build",
    "build:mobile": "CAPACITOR_BUILD=true next build",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "start": "node dist/main.js",
    "test:pdf": "tsx scripts/test-maximal-pdf.ts",
    "test:canonical": "tsx scripts/test-canonical-reconciliation.ts",
    "test:report-coherence": "tsx scripts/test-report-financial-coherence.ts",
    "test:engine": "tsx scripts/test-valuation-engine.ts",
    "test:omwise-calibration": "tsx scripts/test-omwise-calibration.ts",
    "test:scale-modifier": "tsx scripts/test-scale-modifier-pipeline.ts",
    "test:currency-normalize": "tsx scripts/test-currency-normalize.ts",
    "test:monday-leads": "tsx scripts/test-monday-leads-e2e.ts",
    "test:monday-lead": "tsx scripts/test-monday-lead.ts",
    "monday:introspect": "tsx scripts/monday-introspect.ts",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true && chmod +x .githooks/pre-commit 2>/dev/null || true"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sparticuz/chromium": "^149.0.0",
    "@supabase/supabase-js": "^2.107.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@vercel/functions": "^2.2.13",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.21.0",
    "next": "^14.2.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.0",
    "puppeteer-core": "^25.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.8.0",
    "rxjs": "^7.8.1",
    "three": "^0.184.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.9",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0"
  }
}
