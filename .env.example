# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# PostgreSQL — Supavisor transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
SUPABASE_POOLER_REGION="eu-central-1"

# Optional overrides
# DATABASE_POOLER_URL=
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=

PG_SSL=true
JWT_SECRET="change-me-in-production"

# Email dispatch (optional — PDF still downloads if missing)
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# EMAIL_FROM=Equify by SBC <reports@yourdomain.com>

# WhatsApp dispatch (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# Monday.com CRM (lead capture from wizard Step 1)
MONDAY_API_KEY="your-monday-api-token"
MONDAY_BOARD_ID="your-board-id"
# Optional explicit column IDs (auto-discovered from board titles when omitted)
# MONDAY_COLUMN_EMAIL=
# MONDAY_COLUMN_PHONE=
# MONDAY_COLUMN_COMPANY_NAME=
# MONDAY_COLUMN_NATIONAL_ID=
# MONDAY_COLUMN_CORPORATE_TAX_ID=
# MONDAY_COLUMN_VALUATION_MIDPOINT=
# MONDAY_COLUMN_SECTOR=
# MONDAY_COLUMN_FILES=files
